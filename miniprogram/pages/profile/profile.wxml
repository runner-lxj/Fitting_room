<view class="page {{themeClass}}">
  <!-- 渐变头部 -->
  <view class="profile-header">
    <view class="avatar-wrap" bindtap="editAvatar">
      <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <image class="avatar" wx:else src="/static/images/avatar-default.png" mode="aspectFill"></image>
      <view class="avatar-edit">
        <view class="icon-add small"></view>
      </view>
    </view>
    <text class="profile-name">{{userInfo.nickName || '未登录'}}</text>
    <text class="profile-stats">衣柜 {{clothesCount}} 件 · 穿搭 {{outfitCount}} 套</text>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="editNickname">
      <view class="icon-menu-dot"></view>
      <text class="menu-text">修改昵称</text>
      <text class="menu-value">{{userInfo.nickName}}</text>
      <view class="icon-chevron"></view>
    </view>
    <view class="menu-item" bindtap="reuploadPhoto">
      <view class="icon-menu-dot"></view>
      <text class="menu-text">上传人身照</text>
      <view class="icon-chevron"></view>
    </view>
    <view class="menu-item" bindtap="goAdmin" wx:if="{{isAdmin}}">
      <view class="icon-menu-dot"></view>
      <text class="menu-text">管理员配置</text>
      <view class="icon-chevron"></view>
    </view>
  </view>

  <view class="menu-section card" style="display:none;">
    <view class="menu-item" bindtap="changeTheme">
      <view class="icon-menu-dot"></view>
      <text class="menu-text">切换主题</text>
      <text class="menu-value">{{themeName}}</text>
      <view class="icon-chevron"></view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item">
      <view class="icon-menu-dot"></view>
      <text class="menu-text">关于穿搭助手</text>
      <text class="menu-value">v0.2</text>
      <view class="icon-chevron"></view>
    </view>
  </view>
</view>