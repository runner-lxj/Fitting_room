<view class="page {{themeClass}}">
  <view class="home-header animate-in">
    <view class="home-header-row">
      <view>
        <text class="home-greeting" style="font-family: ZCOOLKuaiLe">{{greeting}}{{userName ? "，" + userName : ""}}</text>
        <text class="home-greeting-sub">{{outfitSuggestion}}</text>
        <view class="home-location" bindtap="onLocationTap">
          <text class="loc-emoji">📍</text>
          <text>{{locationName}}</text>
          <text class="location-switch-text" bindtap="onLocationTap">切换</text>
        </view>
      </view>
      <view class="digital-avatar">
        <image class="digital-avatar-img" src="/static/images/avatar-character.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="section-padding animate-in animate-delay-1">
    <view class="card weather-card">
      <view class="weather-main">
        <view class="weather-temp">
          <text class="temp-num">{{weather.temp}}</text>
          <text class="temp-unit">°C</text>
        </view>
        <view class="weather-info">
          <text class="weather-desc">{{weather.condition}}</text>
          <text class="weather-detail">{{weather.wind}} · 湿度 {{weather.humidity}}%</text>
        </view>
        <view class="weather-icon-box">
          <text class="weather-emoji">☁️</text>
        </view>
      </view>
      <view class="weather-tip">
        <text class="tip-emoji">💡</text>
        <text>{{weather.tip}}</text>
      </view>
    </view>
  </view>

  <view class="section-padding animate-in animate-delay-2">
    <view class="section-header">
      <text class="section-title">今日推荐</text>
      <text class="section-more" bindtap="refreshOutfits">换一批</text>
    </view>
    <view class="loading-dots" wx:if="{{loading}}">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
    <view class="outfit-single-wrap" wx:if="{{!loading && outfits.length > 0}}" bindtap="goDetail" data-id="{{outfits[0]._id}}">
      <view class="outfit-single-card">
        <view class="outfit-cloth-grid">
          <view class="outfit-cloth-item" wx:for="{{outfits[0].clothImages}}" wx:key="*this">
            <image class="outfit-cloth-img" src="{{item}}" mode="aspectFill"></image>
          </view>
          <view class="outfit-cloth-item outfit-cloth-empty" wx:if="{{!outfits[0].clothImages || outfits[0].clothImages.length === 0}}">
            <view class="icon-hanger"></view>
          </view>
        </view>
        <view class="outfit-info">
          <text class="outfit-name">{{outfits[0].name}}</text>
          <text class="outfit-occasion">{{outfits[0].occasion}} · {{outfits[0].season}}</text>
          <view class="outfit-tags">
            <text class="outfit-tag tag-weather" wx:for="{{outfits[0].weather_tags}}" wx:key="*this">{{item}}</text>
            <text class="outfit-tag tag-style" wx:if="{{outfits[0].style_summary}}">{{outfits[0].style_summary}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{!loading && outfits.length === 0}}">
      <view class="empty-icon-box">
        <view class="icon-empty-box"></view>
      </view>
      <text class="empty-text">还没有搭配方案</text>
      <text class="empty-sub">去衣柜添加衣服，然后一键搭配</text>
      <button class="btn-primary empty-btn" bindtap="goOutfits">去搭配</button>
    </view>
  </view>

  <view class="section-padding animate-in animate-delay-3">
    <view class="quick-actions">
      <view class="action-item" bindtap="goWardrobe">
        <view class="action-icon" style="background: var(--gradient-warm);">
          <text class="action-emoji">👔</text>
        </view>
        <text class="action-text">我的衣柜</text>
        <text class="action-count">{{clothesCount}} 件</text>
      </view>
      <view class="action-item" bindtap="goAddClothes">
        <view class="action-icon" style="background: var(--gradient-cool);">
          <text class="action-emoji">📷</text>
        </view>
        <text class="action-text">添加衣服</text>
        <text class="action-count">拍照入库</text>
      </view>
      <view class="action-item" bindtap="goMyOutfits">
        <view class="action-icon" style="background: var(--gradient-main);">
          <text class="action-emoji">⭐</text>
        </view>
        <text class="action-text">我的穿搭</text>
        <text class="action-count">{{outfitCount}} 套</text>
      </view>
    </view>
  </view>
</view>
