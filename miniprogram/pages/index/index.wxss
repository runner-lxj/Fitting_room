/* pages/index/index.wxss */
.page { min-height: 100vh; background: var(--bg-page); }

.header-content { position: relative; z-index: 2; }
.greeting { margin-top: 20rpx; }
.greeting-text { font-size: 40rpx; font-weight: 600; color: #FFF; display: block; }
.greeting-sub { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; display: block; }

.weather-section { padding: 0 32rpx; position: relative; z-index: 3; margin-top: -20rpx; }
.weather-card { padding: 32rpx !important; }
.weather-main { display: flex; align-items: center; gap: 24rpx; }
.weather-temp { display: flex; align-items: flex-start; }
.temp-num { font-size: 72rpx; font-weight: 700; color: var(--primary); line-height: 1; }
.temp-unit { font-size: 28rpx; color: var(--primary); margin-top: 8rpx; }
.weather-info { flex: 1; }
.weather-desc { font-size: 30rpx; font-weight: 500; display: block; }
.weather-detail { font-size: 24rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
.weather-icon { width: 80rpx; height: 80rpx; }
.weather-tip { display: flex; align-items: center; gap: 12rpx; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--border); }
.tip-icon { font-size: 28rpx; }
.tip-text { font-size: 24rpx; color: var(--text-secondary); flex: 1; }

.section { padding: 32rpx 32rpx 0; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 600; }
.section-more { font-size: 26rpx; color: var(--primary); }

.outfit-scroll { white-space: nowrap; }
.outfit-item { display: inline-block; width: 320rpx; margin-right: 24rpx; padding: 0 !important; overflow: hidden; vertical-align: top; }
.outfit-img { width: 320rpx; height: 400rpx; border-radius: 16rpx 16rpx 0 0; }
.outfit-info { padding: 20rpx; }
.outfit-name { font-size: 28rpx; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.outfit-occasion { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }
.outfit-score { padding: 0 20rpx 20rpx; }
.score-num { font-size: 22rpx; color: var(--primary); background: var(--bg-input); padding: 4rpx 16rpx; border-radius: 999rpx; }

.empty-text { font-size: 32rpx; font-weight: 500; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; margin-bottom: 32rpx; }
.empty-btn { margin-top: 16rpx; }

.quick-actions { display: flex; gap: 24rpx; padding: 32rpx; }
.action-item { flex: 1; background: var(--bg-card); border-radius: var(--radius-md); padding: 28rpx 20rpx; text-align: center; box-shadow: var(--shadow); }
.action-icon { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin: 0 auto 16rpx; }
.action-text { font-size: 26rpx; font-weight: 500; display: block; }
.action-count, .action-sub { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }