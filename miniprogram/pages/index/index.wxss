/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
}

/* 问候区 */
.home-header {
  padding: 16rpx 40rpx 32rpx;
  position: relative;
  background: linear-gradient(180deg, rgba(212,149,106,0.06) 0%, rgba(250,248,245,0) 100%);
}

.home-header-row {
  position: relative;
}

.home-greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 1rpx;
  display: block;
}

.home-greeting-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
  line-height: 1.6;
}

.home-location {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 10rpx 24rpx;
  background: rgba(212,149,106,0.08);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--primary-dark);
}

.home-location svg {
  width: 26rpx;
  height: 26rpx;
}

.location-switch-text {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 4rpx;
}

/* 数字人占位 */
.digital-avatar {
  position: absolute;
  right: -16rpx;
  bottom: -100rpx;
  z-index: 20;
}

.digital-avatar-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  object-fit: cover;
}

/* section padding */
.section-padding {
  padding: 0 40rpx;
}

.section-padding.animate-delay-1 {
  margin-top: -16rpx;
  position: relative;
  z-index: 3;
}

.section-padding.animate-delay-2 {
  margin-top: 24rpx;
}

.section-padding.animate-delay-3 {
  margin-top: 24rpx;
}

/* 天气卡片 */
.weather-card {
  position: relative;
  overflow: hidden;
}

.weather-card::before {
  content: "";
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(212,149,106,0.06) 0%, transparent 70%);
  border-radius: 50%;
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.weather-temp {
  display: flex;
  align-items: flex-start;
}

.temp-num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
  letter-spacing: -2rpx;
}

.temp-unit {
  font-size: 32rpx;
  color: var(--primary);
  margin-top: 8rpx;
  font-weight: 500;
}

.weather-info {
  flex: 1;
}

.weather-desc {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.weather-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
}

.weather-icon-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
}

.weather-icon-box svg {
  width: 56rpx;
  height: 56rpx;
  stroke: var(--primary);
  stroke-width: 1.5;
}

.weather-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--border);
}

.weather-tip svg {
  width: 32rpx;
  height: 32rpx;
  stroke: var(--primary-light);
  stroke-width: 1.8;
  flex-shrink: 0;
}

.weather-tip text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 今日推荐 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.6rpx;
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 单套推荐卡 */
.outfit-single-wrap {
  display: flex;
  justify-content: center;
}

.outfit-single-card {
  width: 100%;
  max-width: 600rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(212,149,106,0.06);
}

.outfit-img-placeholder {
  width: 100%;
  height: 340rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #f5f0eb 0%, #ede6df 100%);
  position: relative;
}

.outfit-img-placeholder svg {
  width: 80rpx;
  height: 80rpx;
  stroke: var(--text-hint);
  stroke-width: 1;
  opacity: 0.5;
}

.outfit-img-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.outfit-img {
  width: 100%;
  height: 100%;
}

.outfit-info {
  padding: 28rpx;
}

.outfit-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.outfit-occasion {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
}

.outfit-score {
  display: inline-block;
  margin-top: 16rpx;
  padding: 4rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--bg-input);
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 空状态 */
.empty-icon-box {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon-box svg {
  width: 120rpx;
  height: 120rpx;
  stroke: var(--text-hint);
  stroke-width: 0.8;
  opacity: 0.4;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(212,149,106,0.06);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.action-icon svg {
  width: 44rpx;
  height: 44rpx;
  stroke: #fff;
  stroke-width: 1.8;
}

.action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.action-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
}

/* 推荐搭配衣物网格 */
.outfit-cloth-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rpx;
  width: 100%;
  aspect-ratio: 1;
  background: var(--bg-card);
}
.outfit-cloth-item {
  width: 100%;
  height: 100%;
  overflow: hidden;
}
.outfit-cloth-img {
  width: 100%;
  height: 100%;
}
.outfit-cloth-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f0eb 0%, #ede6df 100%);
}

/* 快捷入口图标 */
.action-emoji {
  font-size: 40rpx;
  line-height: 1;
}

/* 首页搭配标签 */
.outfit-info {
  padding: 20rpx 24rpx;
}
.outfit-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}
.outfit-occasion {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}
.outfit-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: nowrap;
}
.outfit-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.outfit-tag.tag-weather {
  background: rgba(123,158,184,0.1);
  color: #5A7F9A;
}
.outfit-tag.tag-season {
  background: rgba(212,149,106,0.1);
  color: var(--primary-dark);
}
.outfit-tag.tag-style {
  background: rgba(160,141,176,0.1);
  color: #7E6B90;
}

/* 定位刷新按钮 */
.loc-refresh {
  font-size: 28rpx;
  color: var(--primary);
  margin-left: 8rpx;
  line-height: 1;
}
