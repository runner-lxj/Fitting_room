.page { min-height: 100vh; background: var(--bg-page); }
.profile-header { background: var(--gradient-main); padding: 100rpx 32rpx 60rpx; text-align: center; border-radius: 0 0 40rpx 40rpx; }
.avatar-wrap { width: 140rpx; height: 140rpx; border-radius: 50%; border: 6rpx solid rgba(255,255,255,0.5); overflow: hidden; margin: 0 auto 20rpx; }
.avatar { width: 100%; height: 100%; }
.user-name { font-size: 36rpx; font-weight: 600; color: #FFF; display: block; }
.user-stats { font-size: 26rpx; color: rgba(255,255,255,0.85); display: block; margin-top: 8rpx; }
.menu-section { margin: 24rpx 32rpx; padding: 0 !important; }
.menu-item { display: flex; align-items: center; padding: 28rpx 32rpx; border-bottom: 1rpx solid var(--border); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-theme-name { font-size: 26rpx; color: var(--primary); margin-right: 8rpx; }
.menu-arrow { font-size: 32rpx; color: var(--text-hint); }