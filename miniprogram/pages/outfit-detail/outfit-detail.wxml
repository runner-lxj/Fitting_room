<view class="page {{themeClass}}">
  <!-- 顶部导航栏（自定义） -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-bar-inner">
      <view class="detail-back" bindtap="goBack">
        <view class="back-arrow"></view>
      </view>
      <!-- 右侧留空给微信胶囊按钮 -->
    </view>
  </view>

  <!-- 大图 Hero 区 -->
  <view class="detail-hero">
    <view class="hero-grid" wx:if="{{outfit.clothImages.length > 0}}">
      <image class="hero-grid-img" wx:for="{{outfit.clothImages}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
    </view>
    <view class="hero-grid hero-grid-1" wx:else>
      <view class="icon-hanger"></view>
    </view>
    <!-- 匹配度徽章：叠在图片右下角 -->
    <view class="hero-badge" wx:if="{{outfit.scoreText}}">
      匹配 {{outfit.scoreText}}
    </view>
  </view>
  
  <view class="detail-body">
    <!-- AI 搭配理由 -->
    <view class="card ai-reason-card" wx:if="{{outfit.ai_reason}}">
      <view class="ai-reason-header">
        <text class="ai-reason-title">ℹ️ AI 搭配理由</text>
      </view>
      <text class="ai-reason-text">{{outfit.ai_reason}}</text>
    </view>

    <!-- 搭配信息 -->
    <view class="card">
      <view class="detail-header">
        <text class="detail-name">{{outfit.name}}</text>
        <view class="detail-meta">
          <text class="tag tag-accent" wx:if="{{outfit.weather_desc}}">{{outfit.weather_desc}}</text>
          <text class="tag tag-accent" wx:if="{{outfit.occasion}}">{{outfit.occasion}}</text>
        </view>
      </view>
      <text class="detail-desc" wx:if="{{outfit.style_summary}}">风格：{{outfit.style_summary}}</text>
    </view>

    <!-- 搭配单品 -->
    <view class="card items-card">
      <text class="card-title">搭配单品</text>
      <view class="items-list">
        <view class="item-row" wx:for="{{displayItems}}" wx:key="id">
          <view class="item-img">
            <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFit" class="item-img-inner"></image>
            <view class="icon-hanger" wx:else></view>
          </view>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-cat">{{item.categoryLabel}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar safe-bottom" wx:if="{{outfit.status === 'pending'}}">
    <button class="btn-secondary" bindtap="rejectOutfit">舍弃</button>
    <button class="btn-primary" bindtap="acceptOutfit">
      ✨ 采纳搭配
    </button>
  </view>
  <view class="action-bar safe-bottom" wx:else>
    <text class="accepted-text">已采纳</text>
  </view>
</view>