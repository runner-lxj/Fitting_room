<view class="page {{themeClass}}">
  <view class="profile-header">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatarUrl || '/static/icons/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
    <text class="user-stats">衣柜 {{clothesCount}} 件 · 穿搭 {{outfitCount}} 套</text>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="reuploadPhoto">
      <text class="menu-icon">📸</text>
      <text class="menu-text">重新上传人身照</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAdmin" wx:if="{{isAdmin}}">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">管理员配置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="changeTheme">
      <text class="menu-icon">🎨</text>
      <text class="menu-text">切换主题</text>
      <text class="menu-theme-name">{{themeName}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>