/* pages/outfit-detail/outfit-detail.wxss */
.page {
  background: var(--bg-page);
  min-height: 100vh;
}

/* Hero 区域 */
.detail-hero {
  width: 100%;
  height: 560rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f0eb 0%, #ede6df 100%);
  position: relative;
}

.detail-back {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.detail-back svg {
  width: 40rpx;
  height: 40rpx;
  stroke: var(--text-primary);
  stroke-width: 2;
}

.hero-img {
  width: 90%;
  height: 520rpx;
}

.hero-main {
  width: 160rpx;
  height: 160rpx;
  stroke: var(--text-hint);
  stroke-width: 0.8;
  opacity: 0.3;
}

.detail-hero-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.9);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-hero-badge svg {
  width: 24rpx;
  height: 24rpx;
  stroke: var(--primary);
  stroke-width: 2;
}

/* 主体内容 */
.detail-body {
  padding: 0 40rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
  padding-bottom: 200rpx;
}

/* AI 搭配理由 */
.ai-reason-card {
  background: linear-gradient(135deg, rgba(212,149,106,0.04) 0%, rgba(232,196,168,0.06) 100%);
  border: 1rpx solid rgba(212,149,106,0.12);
}

.ai-reason-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.ai-reason-header svg {
  width: 36rpx;
  height: 36rpx;
  stroke: var(--primary);
  stroke-width: 1.8;
  flex-shrink: 0;
}

.ai-reason-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-dark);
}

.ai-reason-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 搭配信息 */
.detail-header {
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 0.6rpx;
}

.detail-meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.detail-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 搭配单品 */
.items-card {
  margin-top: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 28rpx;
}

.items-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.item-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, #f5f0eb, #ede6df);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.item-img svg {
  width: 48rpx;
  height: 48rpx;
  stroke: var(--text-hint);
  stroke-width: 1;
  opacity: 0.4;
}

.item-img-inner {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.item-cat {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.item-arrow {
  width: 32rpx;
  height: 32rpx;
  stroke: var(--text-hint);
  stroke-width: 1.5;
  flex-shrink: 0;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 28rpx 40rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid var(--border);
  z-index: 5;
}

.action-bar .btn-secondary,
.action-bar .btn-primary {
  flex: 1;
  padding: 24rpx 0;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  stroke: #fff;
  stroke-width: 2;
}

.accepted-text {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 24rpx;
}