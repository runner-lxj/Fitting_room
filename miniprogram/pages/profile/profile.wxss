/* pages/profile/profile.wxss */
.page {
  min-height: 100vh;
  background: var(--bg-page);
}

/* 渐变头部 */
.profile-header {
  background: var(--gradient-main);
  padding: 60rpx 40rpx 72rpx;
  text-align: center;
  position: relative;
}

.profile-header::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48rpx;
  background: var(--bg-page);
  border-radius: 48rpx 48rpx 0 0;
}

.avatar-wrap {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  border: 6rpx solid rgba(255,255,255,0.5);
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #E8C4A8, #D4956A);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-wrap svg {
  width: 72rpx;
  height: 72rpx;
  stroke: #fff;
  stroke-width: 1.5;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit svg {
  width: 24rpx;
  height: 24rpx;
  stroke: #fff;
  stroke-width: 2;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 1;
  display: block;
}

.profile-stats {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
  display: block;
}

/* 菜单列表 */
.menu-section {
  margin: 24rpx 40rpx;
  padding: 0 !important;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item svg {
  width: 40rpx;
  height: 40rpx;
  stroke: var(--primary);
  stroke-width: 1.8;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-value {
  font-size: 26rpx;
  color: var(--primary);
  margin-right: 16rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  stroke: var(--text-hint);
  stroke-width: 1.8;
  flex-shrink: 0;
}