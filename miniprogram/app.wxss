/* ========== 全局设计 Token 系统 ========== */

/* --- 樱花粉主题（默认） --- */
page {
  --primary: #FF7E8D;
  --primary-light: #FFB5C2;
  --primary-dark: #E8556A;
  --secondary: #B8A9C9;
  --accent: #FFD4A8;
  --bg-page: #FFF5F5;
  --bg-card: #FFFFFF;
  --bg-input: #FFF0F0;
  --text-primary: #2D2D3A;
  --text-secondary: #8E8E9A;
  --text-hint: #C0C0CC;
  --border: #F0E0E4;
  --shadow: 0 4rpx 24rpx rgba(255, 126, 141, 0.12);
  --gradient-main: linear-gradient(135deg, #FF7E8D 0%, #FFB5C2 100%);
  --gradient-warm: linear-gradient(135deg, #FFD4A8 0%, #FFB5C2 100%);
  --gradient-cool: linear-gradient(135deg, #B8A9C9 0%, #FFB5C2 100%);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
}

/* --- 薄荷绿主题 --- */
page.theme-mint {
  --primary: #7ECFB3;
  --primary-light: #A8E6CF;
  --primary-dark: #5BAF93;
  --secondary: #A8D8EA;
  --accent: #FFD3B6;
  --bg-page: #F0FAF5;
  --bg-card: #FFFFFF;
  --bg-input: #E8F8F0;
  --text-primary: #2D3A2F;
  --text-secondary: #7A8E7C;
  --text-hint: #B8C8BA;
  --border: #D0E8D8;
  --shadow: 0 4rpx 24rpx rgba(126, 207, 179, 0.12);
  --gradient-main: linear-gradient(135deg, #7ECFB3 0%, #A8E6CF 100%);
  --gradient-warm: linear-gradient(135deg, #FFD3B6 0%, #A8E6CF 100%);
  --gradient-cool: linear-gradient(135deg, #A8D8EA 0%, #A8E6CF 100%);
}

/* --- 暗夜紫主题 --- */
page.theme-purple {
  --primary: #6C5CE7;
  --primary-light: #A29BFE;
  --primary-dark: #5A4BD1;
  --secondary: #FD79A8;
  --accent: #FFEAA7;
  --bg-page: #F0EEFF;
  --bg-card: #FFFFFF;
  --bg-input: #EDE8FF;
  --text-primary: #2D2D3A;
  --text-secondary: #8E8EA0;
  --text-hint: #C0B8D8;
  --border: #DDD8F0;
  --shadow: 0 4rpx 24rpx rgba(108, 92, 231, 0.12);
  --gradient-main: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  --gradient-warm: linear-gradient(135deg, #FD79A8 0%, #A29BFE 100%);
  --gradient-cool: linear-gradient(135deg, #74B9FF 0%, #A29BFE 100%);
}

/* ========== 全局基础样式 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

/* 渐变头部 */
.gradient-header {
  background: var(--gradient-main);
  padding: 80rpx 32rpx 48rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.gradient-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: var(--bg-page);
  border-radius: 40rpx 40rpx 0 0;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

/* 胶囊按钮 */
.btn-primary {
  background: var(--gradient-main);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 141, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-full);
  padding: 18rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  background: var(--bg-input);
  color: var(--primary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: var(--spacing-md) 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
  color: var(--text-hint);
}

.empty-state .empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  padding: 48rpx;
}

.loading-dots .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-light);
  animation: dotPulse 1.2s ease-in-out infinite;
}

.loading-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 安全区适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}