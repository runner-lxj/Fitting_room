.page { min-height: 100vh; background: var(--bg-page); }
.gradient-header.short { padding-bottom: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 600; color: #FFF; }
.config-section { margin: 24rpx 32rpx; padding: 32rpx !important; }
.section-label { font-size: 28rpx; font-weight: 600; color: var(--primary); display: block; margin-bottom: 24rpx; }
.form-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.form-row:last-of-type { border-bottom: none; }
.form-label { width: 200rpx; font-size: 28rpx; color: var(--text-secondary); flex-shrink: 0; }
.form-value { flex: 1; font-size: 28rpx; color: var(--text-primary); text-align: right; }
.slider { flex: 1; }
.prompt-input { width: 100%; min-height: 200rpx; padding: 20rpx; background: var(--bg-input); border-radius: var(--radius-md); font-size: 26rpx; line-height: 1.8; box-sizing: border-box; }
.btn-wrap { padding: 32rpx; }