/* ========== 全局设计 Token 系统 — 柔光杂志 ========== */

/* --- 奶油白主题（默认） --- */
page {
  --primary: #D4956A;
  --primary-light: #E8C4A8;
  --primary-dark: #B87040;
  --secondary: #8B7D6B;
  --accent: #C2847A;
  --bg-page: #FAF8F5;
  --bg-card: #FFFFFF;
  --bg-input: #F5F0EB;
  --text-primary: #2C2520;
  --text-secondary: #9A8E82;
  --text-hint: #C8BEB4;
  --border: #EDE6DF;
  --shadow: 0 2rpx 20rpx rgba(180,150,120,0.08);
  --gradient-main: linear-gradient(160deg, #D4956A 0%, #E8C4A8 100%);
  --gradient-warm: linear-gradient(160deg, #E8C4A8 0%, #C2847A 100%);
  --gradient-cool: linear-gradient(160deg, #A08DB0 0%, #E8C4A8 100%);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-full: 999rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
}

/* --- 雾霾蓝主题 --- */
page.theme-blue {
  --primary: #7B9EB8;
  --primary-light: #B0C8DA;
  --primary-dark: #5A7F9A;
  --secondary: #8B7D6B;
  --accent: #C2847A;
  --bg-page: #F4F7FA;
  --bg-card: #FFFFFF;
  --bg-input: #EBF0F5;
  --text-primary: #2C2520;
  --text-secondary: #9A8E82;
  --text-hint: #C8BEB4;
  --border: #D8E2EA;
  --shadow: 0 2rpx 20rpx rgba(123,158,184,0.08);
  --gradient-main: linear-gradient(160deg, #7B9EB8 0%, #B0C8DA 100%);
  --gradient-warm: linear-gradient(160deg, #B0C8DA 0%, #C2847A 100%);
  --gradient-cool: linear-gradient(160deg, #A08DB0 0%, #B0C8DA 100%);
}

/* --- 薰衣草主题 --- */
page.theme-lavender {
  --primary: #A08DB0;
  --primary-light: #C4B8D4;
  --primary-dark: #7E6B90;
  --secondary: #8B7D6B;
  --accent: #C2847A;
  --bg-page: #F7F3FA;
  --bg-card: #FFFFFF;
  --bg-input: #F0EBF5;
  --text-primary: #2C2520;
  --text-secondary: #9A8E82;
  --text-hint: #C8BEB4;
  --border: #E0D8E8;
  --shadow: 0 2rpx 20rpx rgba(160,141,176,0.08);
  --gradient-main: linear-gradient(160deg, #A08DB0 0%, #C4B8D4 100%);
  --gradient-warm: linear-gradient(160deg, #C4B8D4 0%, #C2847A 100%);
  --gradient-cool: linear-gradient(160deg, #7B9EB8 0%, #C4B8D4 100%);
}

/* ========== 全局基础样式 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

/* 渐变头部 */
.gradient-header {
  background: var(--gradient-main);
  padding: 16rpx 40rpx 40rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.gradient-header::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 0;
  right: 0;
  height: 40rpx;
  background: var(--bg-page);
  border-radius: 20rpx 20rpx 0 0;
}

.gradient-header.short {
  padding-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  letter-spacing: 1rpx;
}

.page-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 8rpx;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid rgba(212,149,106,0.06);
}

/* 胶囊按钮 */
.btn-primary {
  background: var(--gradient-main);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(212,149,106,0.25);
  letter-spacing: 1rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--primary);
  border: 3rpx solid var(--primary);
  border-radius: var(--radius-full);
  padding: 18rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  background: var(--bg-input);
  color: var(--secondary);
  font-weight: 500;
  letter-spacing: 0.6rpx;
}

.tag-accent {
  background: rgba(212,149,106,0.1);
  color: var(--primary-dark);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: var(--spacing-md) 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
  color: var(--text-hint);
}

.empty-state .empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
}

.empty-sub {
  font-size: 26rpx;
  margin-bottom: 32rpx;
  color: var(--text-hint);
}

.empty-btn {
  margin-top: 16rpx;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  padding: 48rpx;
}

.loading-dots .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-light);
  animation: dotPulse 1.2s ease-in-out infinite;
}

.loading-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 安全区适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面入场动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-in {
  animation: fadeInUp 0.4s ease forwards;
}
