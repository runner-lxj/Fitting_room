/* pages/clothes-add/clothes-add.wxss */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 140rpx;
}

/* 标题区 */
.gradient-header.short {
  padding-bottom: 24rpx;
}

/* 上传网格 */
.upload-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx 40rpx;
}

.upload-item {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(212,149,106,0.06);
}

.upload-thumb {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #f5f0eb, #ede6df);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-thumb-img {
  width: 100%;
  height: 100%;
}

/* 状态角标 */
.upload-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
}

.badge-recognized {
  background: rgba(160,141,176,0.9);
  color: #fff;
}

.badge-recognizing {
  background: rgba(212,149,106,0.9);
  color: #fff;
}

.badge-uploading {
  background: rgba(255,255,255,0.9);
  color: #999;
}

.badge-pending {
  background: rgba(255,255,255,0.9);
  color: #FFA726;
}

.badge-failed {
  background: rgba(244,67,54,0.9);
  color: #fff;
}

/* 识别中动画 */
.recognizing-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 删除按钮 */
.upload-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-remove svg {
  width: 24rpx;
  height: 24rpx;
  stroke: #fff;
  stroke-width: 2.5;
}

/* 上传区域 */
.upload-section {
  padding: 0 40rpx;
}

.upload-area {
  margin-top: 24rpx;
  border: 4rpx dashed var(--border);
  border-radius: var(--radius-lg);
  padding: 80rpx 40rpx;
  text-align: center;
  background: var(--bg-card);
}

.upload-area svg {
  width: 80rpx;
  height: 80rpx;
  stroke: var(--text-hint);
  stroke-width: 1.2;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}

/* 编辑弹窗 */
.edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.edit-panel {
  width: 100%;
  background: var(--bg-card);
  border-radius: 64rpx 64rpx 0 0;
  padding: 64rpx;
  max-height: 80vh;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.edit-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.edit-close {
  padding: 16rpx;
}

.edit-close svg {
  width: 40rpx;
  height: 40rpx;
  stroke: var(--text-secondary);
  stroke-width: 2;
}

.edit-form {
  margin-bottom: 48rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: right;
}

.tags-row {
  flex: 1;
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  background: var(--bg-input);
  color: var(--primary);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid var(--border);
}