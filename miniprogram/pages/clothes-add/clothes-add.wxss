/* pages/clothes-add/clothes-add.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 100rpx; }
.gradient-header.short { padding-bottom: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 600; color: #FFF; }
.page-sub { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 4rpx; }

/* 已上传列表 */
.upload-list { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 24rpx 32rpx; }
.upload-item { position: relative; padding: 0 !important; overflow: hidden; }
.item-thumb { width: 100%; height: 240rpx; display: block; }

/* 状态角标 */
.status-badge { position: absolute; bottom: 0; left: 0; right: 0; padding: 8rpx 16rpx; font-size: 20rpx; font-weight: 500; text-align: center; }
.badge-uploading { background: rgba(255,255,255,0.9); color: #999; }
.badge-pending { background: rgba(255,255,255,0.9); color: #FFA726; }
.badge-recognizing { background: rgba(255,126,141,0.9); color: #FFF; }
.badge-recognized { background: rgba(76,175,80,0.9); color: #FFF; }
.badge-failed { background: rgba(244,67,54,0.9); color: #FFF; }

/* 识别中动画 */
.recognizing-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.5); display: flex; align-items: center; justify-content: center; }
.spinner { width: 48rpx; height: 48rpx; border: 4rpx solid var(--primary-light); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* 删除按钮 */
.remove-btn { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; border-radius: 50%; background: rgba(0,0,0,0.4); color: #FFF; font-size: 20rpx; display: flex; align-items: center; justify-content: center; }

/* 上传区域 */
.upload-section { padding: 0 32rpx; }
.upload-area { background: var(--bg-card); border: 3rpx dashed var(--border); border-radius: var(--radius-lg); padding: 60rpx 48rpx; text-align: center; box-shadow: var(--shadow); }
.upload-icon { font-size: 56rpx; display: block; margin-bottom: 16rpx; }
.upload-text { font-size: 30rpx; font-weight: 500; display: block; }
.upload-hint { font-size: 24rpx; color: var(--text-secondary); display: block; margin-top: 8rpx; }

/* 编辑弹窗 */
.edit-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.edit-panel { width: 100%; background: var(--bg-card); border-radius: 32rpx 32rpx 0 0; padding: 32rpx; max-height: 80vh; }
.edit-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.edit-title { font-size: 32rpx; font-weight: 600; }
.edit-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.edit-form { margin-bottom: 32rpx; }
.form-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.form-label { width: 140rpx; font-size: 28rpx; color: var(--text-secondary); flex-shrink: 0; }
.form-value { flex: 1; font-size: 28rpx; text-align: right; }
.tags-row { flex: 1; display: flex; gap: 8rpx; justify-content: flex-end; flex-wrap: wrap; }
.tag { padding: 4rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; background: var(--bg-input); color: var(--primary); }

/* 底部按钮 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 32rpx; background: var(--bg-card); box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); }