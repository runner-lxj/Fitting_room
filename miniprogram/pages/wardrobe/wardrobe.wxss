/* pages/wardrobe/wardrobe.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 120rpx; }
.page-title { font-size: 40rpx; font-weight: 600; color: #FFF; display: block; }
.page-sub { font-size: 26rpx; color: rgba(255,255,255,0.85); display: block; margin-top: 8rpx; }

.tab-scroll { position: relative; z-index: 3; margin-top: -20rpx; padding: 0 32rpx; }
.tab-list { display: flex; gap: 16rpx; white-space: nowrap; padding: 16rpx 0; }
.tab-item { display: inline-flex; align-items: center; gap: 8rpx; padding: 14rpx 28rpx; border-radius: 999rpx; background: var(--bg-card); font-size: 26rpx; color: var(--text-secondary); box-shadow: var(--shadow); }
.tab-item.active { background: var(--gradient-main); color: #FFF; }
.tab-count { font-size: 20rpx; opacity: 0.7; }

.sub-tab-scroll { padding: 0 32rpx; }
.sub-tab-list { display: flex; gap: 12rpx; white-space: nowrap; padding: 12rpx 0; }
.sub-tab-item { display: inline-block; padding: 8rpx 20rpx; border-radius: 999rpx; background: var(--bg-card); font-size: 22rpx; color: var(--text-secondary); border: 1rpx solid var(--border); }
.sub-tab-item.active { background: var(--bg-input); color: var(--primary); border-color: var(--primary); }

.clothes-grid { display: flex; flex-wrap: wrap; gap: 20rpx; padding: 24rpx 32rpx; }
.clothes-item { width: calc(50% - 10rpx); background: var(--bg-card); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow); }
.clothes-img { width: 100%; height: 320rpx; background: #f8f8f8; }
.clothes-tags { padding: 16rpx; display: flex; gap: 8rpx; flex-wrap: wrap; }
.color-tag { min-width: 32rpx; height: 32rpx; padding: 2rpx 12rpx; border-radius: 999rpx; font-size: 20rpx; color: #666; }

.fab-btn { position: fixed; right: 40rpx; bottom: 200rpx; width: 100rpx; height: 100rpx; border-radius: 50%; background: var(--gradient-main); display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 32rpx rgba(255,126,141,0.4); z-index: 100; }
.fab-icon { font-size: 48rpx; color: #FFF; font-weight: 300; }